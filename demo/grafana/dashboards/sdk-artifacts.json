          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT kind, product, channel, app_release, platform, os, device_id, occurred_at AS time, bucket, object_key, CASE WHEN size < 1024 THEN size || ' B' WHEN size < 1048576 THEN round(size/1024.0, 1) || ' KB' ELSE round(size/1048576.0, 1) || ' MB' END AS size_fmt, state, '⬇' AS download FROM artifacts WHERE deleted_at IS NULL AND kind = '$kind' AND product = '$product' AND channel = '$channel' AND platform IN ($platform) AND state IN ($state) AND ('$device_id' = '' OR device_id LIKE '%' || '$device_id' || '%') ORDER BY occurred_at DESC LIMIT 200",
