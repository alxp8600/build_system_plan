{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::sdk-packets/*",
        "arn:aws:s3:::sdk-logs/*",
        "arn:aws:s3:::sdk-packets",
        "arn:aws:s3:::sdk-logs"
      ]
    }
  ]
}