{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:ListBucket", "s3:PutObjectTagging", "s3:GetObjectTagging"],
      "Resource": [
        "arn:aws:s3:::sdk-logs/*",
        "arn:aws:s3:::sdk-packets/*",
        "arn:aws:s3:::sdk-logs",
        "arn:aws:s3:::sdk-packets"
      ]
    }
  ]
}