# ---------- Git SSH ----------
# 在宿主机生成: ssh-keygen -t ed25519 -C "jenkins@ci.intra" -f jenkins/ssh/id_ed25519 -N ""
# 把公钥添加到 GitLab/Gitea Deploy Key，私钥内容填入下面
# 示例: GIT_SSH_PRIVATE_KEY=-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----
# 如果只用 https + token 方式就不需要这个值
GIT_SSH_PRIVATE_KEY=
