# sdk-build-plan/scripts-stub/.env.example
# 拷贝为 .env 后填入真实秘钥；切勿提交到 git。
# 所有 *_PASSWORD / *_SECRET / *_AK / *_SK 至少 32 个字符随机串：
#   openssl rand -base64 32

# ---------- MinIO ----------
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=REPLACE_ME_minio_root

# 客户端 SDK 走的账号 (只允许 PutObject 到 sdk-logs / sdk-dumps)
MINIO_APP_AK=REPLACE_ME
MINIO_APP_SK=REPLACE_ME

# decrypt-proxy 走的账号 (只允许 GetObject + ListBucket)
MINIO_PROXY_AK=REPLACE_ME
MINIO_PROXY_SK=REPLACE_ME

# ---------- catalog Postgres ----------
PG_PASSWORD=REPLACE_ME_pg

# ---------- upload-token 服务 ----------
UPLOAD_JWT_SECRET=REPLACE_ME_jwt
# 与 SDK 内置预共享的 HMAC, 用于 /v1/activate 校验
UPLOAD_ACTIVATE_HMAC=REPLACE_ME_activate

# ---------- decrypt-proxy 服务 ----------
PROXY_SESSION_SECRET=REPLACE_ME_session
OIDC_CLIENT_ID=sdk-decrypt-proxy
OIDC_CLIENT_SECRET=REPLACE_ME_oidc

# 可选: Sentry self-hosted minidump endpoint
# e.g. https://sentry.intra/api/123/minidump/?sentry_key=xxx
SENTRY_MINIDUMP_ENDPOINT=